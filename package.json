{
  "name": "productiviteit-atr",
  "version": "1.0.0",
  "description": "Productiviteit ATR Medewerkers - Desktop applicatie voor het verwerken van rapportages en genereren van productiviteitsoverzichten",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "pretest": "node -e \"try{require('child_process').execSync('npm rebuild better-sqlite3',{stdio:'ignore'})}catch(e){}\"",
    "test": "jest --forceExit --detectOpenHandles",
    "prestart": "node -e \"try{require('child_process').execSync('npx electron-rebuild -f -w better-sqlite3',{stdio:'ignore'})}catch(e){}\"",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "jest": "^29.7.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "exceljs": "^4.4.0"
  },
  "jest": {
    "testMatch": ["**/tests/**/*.js"]
  },
  "build": {
    "appId": "com.atr.productiviteit",
    "productName": "Productiviteit ATR",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.business"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*"
    ]
  }
}
